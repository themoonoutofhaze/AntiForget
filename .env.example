# Google Client IDs
VITE_GOOGLE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8787/api/app/drive/callback

# Server Configuration
APP_SERVER_PORT=8787
FRONTEND_BASE_URL=http://localhost:5173
APP_ENCRYPTION_KEY=
APP_JWT_SECRET=

# Database
# Required: PostgreSQL connection string
DATABASE_URL=
# Optional: used only by one-time migration script
SQLITE_PATH=./server_data/smartrevision.db

# Web Push Notifications (VAPID)
# Generate with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@antiforget.app

# AI Configuration
VITE_MISTRAL_MODEL=mistral-small-latest
