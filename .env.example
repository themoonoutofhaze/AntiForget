VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Backend server
APP_SERVER_PORT=8787
# Required: PostgreSQL connection string
# Local example: postgresql://postgres:postgres@localhost:5432/antiforget
# Supabase example: paste your project connection string
DATABASE_URL=
# Optional: used only by one-time migration script
SQLITE_PATH=./server_data/smartrevision.db
FRONTEND_BASE_URL=http://localhost:5173
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret
# REQUIRED — must be different from APP_ENCRYPTION_KEY
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_JWT_SECRET=replace-with-a-different-long-random-secret

# Google Drive OAuth for file storage (required for uploads)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8787/api/app/drive/callback

# Optional: set default provider (groq | mistral | nvidia | openrouter)
VITE_AI_PROVIDER=groq

# Groq (default model uses GPT OSS 120B)
VITE_GROQ_BASE_URL=
VITE_GROQ_MODEL=openai/gpt-oss-120b

# Mistral (default model uses magistral-small-latest)
VITE_MISTRAL_BASE_URL=
VITE_MISTRAL_MODEL=mistral-small-latest

# NVIDIA
VITE_NVIDIA_BASE_URL=
VITE_NVIDIA_MODEL=meta/llama-3.1-405b-instruct

# OpenRouter
VITE_OPENROUTER_BASE_URL=
VITE_OPENROUTER_MODEL=xiaomi/mimo-v2-flash
